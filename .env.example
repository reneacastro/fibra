# Firebase — pegue em console.firebase.google.com > Project settings > General > Your apps
PUBLIC_FIREBASE_API_KEY=AIza...
PUBLIC_FIREBASE_AUTH_DOMAIN=academia-rene.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=academia-rene
PUBLIC_FIREBASE_STORAGE_BUCKET=academia-rene.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abc123

# OpenRouter — openrouter.ai/keys
# Roteia pro DeepSeek V3 free (100% grátis, ~20 req/min)
PUBLIC_OPENROUTER_API_KEY=sk-or-v1-...

# Endpoint opcional para Atalhos do iPhone postarem dados do Apple Watch
PUBLIC_WATCH_WEBHOOK_URL=https://seu-dominio/api/watch
