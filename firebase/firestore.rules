rules_version = '2';

// ═══════════════════════════════════════════════════════════
//  FIBRA — Firestore Security Rules
// ═══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function notTooLarge() {
      return request.resource.size() < 524288;
    }
    // True se existe relationship ATIVA entre request.auth.uid (trainer)
    // e o uid do path (client), com scope incluindo a string `sc`.
    function hasTrainerAccess(uid, sc) {
      let relId = request.auth.uid + '_' + uid;
      return isSignedIn()
        && exists(/databases/$(database)/documents/relationships/$(relId))
        && get(/databases/$(database)/documents/relationships/$(relId)).data.status == 'active'
        && sc in get(/databases/$(database)/documents/relationships/$(relId)).data.scope;
    }
    function isAdmin() {
      return isSignedIn() && (
        // Fundador (sempre admin)
        request.auth.uid == '6Yqqavyj8odRlNvpiEoUehOspyI2'
        // Ou doc em /admins/{uid} criado por outro admin
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ─── Catálogos públicos (read-only) ──────────────────
    match /exerciseCatalog/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /foodCatalog/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Admins (existência = permissão) ─────────────────
    match /admins/{uid} {
      // Qualquer user autenticado pode checar se ele próprio é admin
      allow read: if isSignedIn() && request.auth.uid == uid;
      // Admin existente pode promover outros
      allow create, delete: if isAdmin() && notTooLarge();
      allow update: if false;
    }

    // ─── Pedidos de virar trainer/nutritionist ───────────
    // User declara intenção escrevendo em /roleRequests/{uid}. Admin aprova.
    match /roleRequests/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) && notTooLarge()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ─── Dados do usuário ────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if (isOwner(uid) || isAdmin()) && notTooLarge();
      allow delete: if false;

      match /exercises/{id} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && notTooLarge();
        allow delete: if isOwner(uid);
      }

      match /workouts/{id} {
        allow read: if isOwner(uid) || hasTrainerAccess(uid, 'workouts');
        allow create, update: if (isOwner(uid) || hasTrainerAccess(uid, 'workouts')) && notTooLarge();
        allow delete: if isOwner(uid) || hasTrainerAccess(uid, 'workouts');
      }

      match /sessions/{id} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && notTooLarge();
        allow update: if isOwner(uid) && notTooLarge()
          && request.resource.data.createdAt == resource.data.createdAt
          && (request.time.toMillis() - resource.data.createdAt) < 172800000;
        allow delete: if isOwner(uid);
      }

      match /exerciseLogs/{exId}/entries/{entryId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && notTooLarge();
        allow delete: if isOwner(uid);
      }

      match /bodyComp/{date} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && notTooLarge();
        allow delete: if isOwner(uid);
      }

      match /schedule/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && notTooLarge();
        allow delete: if isOwner(uid);
      }

      match /dietPlans/{planId} {
        allow read: if isOwner(uid) || hasTrainerAccess(uid, 'diet');
        allow create, update: if (isOwner(uid) || hasTrainerAccess(uid, 'diet')) && notTooLarge();
        allow delete: if isOwner(uid) || hasTrainerAccess(uid, 'diet');
      }

      match /meals/{date} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && notTooLarge();
        allow delete: if isOwner(uid);

        match /items/{itemId} {
          allow read: if isOwner(uid);
          allow create, update: if isOwner(uid) && notTooLarge();
          allow delete: if isOwner(uid);
        }
      }

      match /foods/{foodId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && notTooLarge();
        allow delete: if isOwner(uid);
      }

      match /achievements/{achId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && notTooLarge();
        allow delete: if isOwner(uid);
      }
    }

    // ─── Perfis públicos ─────────────────────────────────
    match /publicProfiles/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && notTooLarge();
      allow delete: if isOwner(uid);
    }

    // ─── Ranking público (opt-in via settings.publicProfile) ──
    match /rankings/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && notTooLarge();
      allow delete: if isOwner(uid);
    }

    // ─── Grupos (comunidade dentro da comunidade) ────────
    match /groups/{groupId} {
      allow read: if resource.data.isPublic == true
        || (isSignedIn() && request.auth.uid in resource.data.memberUids);
      // Criação: owner precisa ser o próprio user e estar no array de membros
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids
        && notTooLarge();
      // Update: owner pode mudar tudo, membros podem ler e sair (retirar
      // a si mesmo do array — permitimos update se memberUids muda e user
      // removeu apenas a si próprio)
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.resource.data.ownerUid  // owner imutável
        && notTooLarge()
        && (
          resource.data.ownerUid == request.auth.uid  // owner pode tudo
          || (
            // Membro só pode sair (memberUids shrinks, remove só a si mesmo)
            resource.data.memberUids.hasAll(request.resource.data.memberUids)
            && !(request.auth.uid in request.resource.data.memberUids)
            && request.auth.uid in resource.data.memberUids
          )
        );
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;

      // Posts do mural
      match /posts/{postId} {
        function groupData() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data;
        }
        function isMember() {
          return isSignedIn() && request.auth.uid in groupData().memberUids;
        }
        allow read: if isMember() || groupData().isPublic == true;
        allow create: if isMember()
          && request.resource.data.authorUid == request.auth.uid
          && notTooLarge();
        allow update, delete: if isSignedIn()
          && (resource.data.authorUid == request.auth.uid
              || groupData().ownerUid == request.auth.uid);
      }
    }

    // ─── Mensagens de chat (subcoleção de relationship) ──
    match /relationships/{relId}/messages/{msgId} {
      function relData() {
        return get(/databases/$(database)/documents/relationships/$(relId)).data;
      }
      function isInRel() {
        return isSignedIn() && (
          relData().trainerUid == request.auth.uid ||
          relData().clientUid == request.auth.uid
        );
      }
      allow read: if isInRel();
      allow create: if isInRel()
        && request.resource.data.senderUid == request.auth.uid
        && notTooLarge();
      allow update, delete: if isSignedIn()
        && resource.data.senderUid == request.auth.uid;
    }

    // ─── Relacionamentos trainer/nutri ⇄ cliente ─────────
    // Doc ID = `${trainerUid}_${clientUid}`
    match /relationships/{relId} {
      // Trainer e client podem ler seu próprio vínculo
      allow read: if isSignedIn() && (
        resource.data.trainerUid == request.auth.uid ||
        resource.data.clientUid == request.auth.uid
      );
      // Trainer inicia o convite (create). O cliente aceita via update.
      allow create: if isSignedIn()
        && request.resource.data.trainerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && notTooLarge();
      // Update: trainer pode mudar scope/note. Client pode aceitar (pending→active)
      // ou encerrar. Ninguém pode trocar os UIDs.
      allow update: if isSignedIn()
        && resource.data.trainerUid == request.resource.data.trainerUid
        && resource.data.clientUid == request.resource.data.clientUid
        && (resource.data.trainerUid == request.auth.uid || resource.data.clientUid == request.auth.uid)
        && notTooLarge();
      allow delete: if isSignedIn() && (
        resource.data.trainerUid == request.auth.uid ||
        resource.data.clientUid == request.auth.uid
      );
    }

    // ─── Treinos compartilhados pela comunidade ──────────
    match /sharedWorkouts/{docId} {
      // Leitura: público abre pra todos; targeted só pro destinatário + dono
      allow read: if resource.data.visibility == 'public'
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid)
        || (isSignedIn() && resource.data.targetUid == request.auth.uid);
      // Listagem queryada: Firestore valida rule por doc — clients precisam
      // filtrar por visibility=='public' ou ownerUid/targetUid do próprio user.
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && notTooLarge()
        && (request.resource.data.visibility == 'public'
            || (request.resource.data.visibility == 'targeted'
                && request.resource.data.targetUid is string));
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && notTooLarge();
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Negação catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
